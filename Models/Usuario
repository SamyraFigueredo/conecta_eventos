const { DataTypes } = require('sequelize');
const sequelize = require('../Config/database_config');

const Usuario = sequelize.define('Usuario', {
    id_usuario: {
    type: DataTypes.INTEGER,
    autoIncrement: true,
    primaryKey: true
},
nome_usuario: {
    type: DataTypes.STRING(100),
    allowNull: false
},
data_nascimento: {
    type: DataTypes.DATEONLY,
    allowNull: false
},
email_usuario: {
    type: DataTypes.STRING(100),
    allowNull: false,
    unique: true
},
tipo_usuario: {
    type: DataTypes.ENUM('admin', 'participante', 'ministrante'),
    allowNull: false
}
}, {
tableName: 'Usuario',
timestamps: false
});

module.exports = Usuario;
